@page
@model TourOperatorWeb.Pages.Admin.QuanLyDoiTacModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "QuanTriHeThong")]
@{
    ViewData["Title"] = "Quản lý công nợ đối tác";
}

<div class="container py-4">
    <h1 class="mb-3">Quản lý công nợ với nhà hàng, khách sạn (đối tác)</h1>
    <p class="text-muted mb-4">
        Danh sách tổng hợp chi phí phải trả cho từng đối tác dựa trên các tour du lịch đã ghép dịch vụ.
    </p>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Tên đối tác</th>
                <th>Loại đối tác</th>
                <th class="text-end">Tổng công nợ phải trả</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var doiTac in Model.DanhSachDoiTac)
        {
            <tr>
                <td>@doiTac.TenDoiTac</td>
                <td>
                    @if (doiTac.LoaiDoiTac == "NhaHang")
                    {
                        <span class="badge bg-info text-dark">Nhà hàng</span>
                    }
                    else if (doiTac.LoaiDoiTac == "KhachSan")
                    {
                        <span class="badge bg-warning text-dark">Khách sạn</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Khác</span>
                    }
                </td>
                <td class="text-end">@doiTac.TongCongNo.ToString("N0") đ</td>
            </tr>
        }
        </tbody>
    </table>
</div>
