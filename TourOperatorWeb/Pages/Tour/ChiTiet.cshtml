@page "{id:int}"
@model TourOperatorWeb.Pages.Tour.ChiTietModel
@{
    ViewData["Title"] = "Chi tiết tour";
}

<div class="container py-4">
    @if (Model.Tour == null)
    {
        <div class="alert alert-warning">
            Không tìm thấy tour phù hợp.
        </div>
        <a asp-page="/Index" class="btn btn-outline-secondary btn-sm">Quay lại trang chủ</a>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3 tour-detail-header">
            <div class="small">
                <a asp-page="/Index" class="text-decoration-none">
                    <i class="bi bi-arrow-left-short me-1"></i>Về trang chủ
                </a>
                <span class="mx-1 text-muted">/</span>
                <span class="text-muted">Chi tiết tour</span>
            </div>
            @if (Model.Tour.LaDeXuat)
            {
                <span class="badge bg-warning-subtle text-dark tour-detail-badge">
                    <i class="bi bi-star-fill me-1"></i>Tour đề cử
                </span>
            }
        </div>

        <div class="row g-4 align-items-stretch">
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm h-100 tour-detail-card">
                    @if (!string.IsNullOrWhiteSpace(Model.Tour.AnhDaiDien))
                    {
                        <img src="@Model.Tour.AnhDaiDien" alt="@Model.Tour.TenTour" class="card-img-top" style="height: 260px; object-fit: cover;" />
                    }
                    <div class="card-body">
                        <h1 class="h4 mb-2">@Model.Tour.TenTour</h1>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-geo-alt me-1"></i>@Model.Tour.DiaDiemKhoiHanh → @Model.Tour.DiaDiemDen
                        </p>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-clock me-1"></i>@Model.Tour.SoNgay ngày
                        </p>
                        <p class="mb-0">
                            <span class="badge bg-light text-dark me-1">Giá từ</span>
                            <span class="fw-bold text-danger fs-5">@Model.Tour.GiaTu.ToString("N0") đ</span>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="mb-3">
                    <h2 class="h5">Mô tả tour</h2>
                    @if (!string.IsNullOrWhiteSpace(Model.Tour.MoTaNgan))
                    {
                        <p class="text-secondary">@Model.Tour.MoTaNgan</p>
                    }
                    else
                    {
                        <p class="text-secondary">Tour du lịch do VietTour tổ chức, lịch trình linh hoạt và phù hợp cho nhiều đối tượng khách.</p>
                    }
                </div>

                @if (!Model.DaDangNhap)
                {
                    <div class="alert alert-info small">
                        Vui lòng <a asp-page="/DangNhap">đăng nhập</a> để đặt tour và xem lịch sử đặt tour của bạn.
                    </div>
                }
                else
                {
                    if (!string.IsNullOrEmpty(Model.ThongBaoDatTour))
                    {
                        <div class="alert alert-success small">
                            @Model.ThongBaoDatTour
                        </div>
                    }

                    <div class="card border-0 shadow-sm mt-3 tour-booking-card">
                        <div class="card-body">
                            <h2 class="h6 mb-1">Đặt tour này</h2>
                            <p class="text-muted small mb-3">Chọn ngày khởi hành và số lượng khách, VietTour sẽ liên hệ xác nhận trong thời gian sớm nhất.</p>
                            <form method="post" asp-page-handler="DatTour">
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label asp-for="Input.NgayKhoiHanh" class="form-label">Ngày khởi hành</label>
                                        <input asp-for="Input.NgayKhoiHanh" class="form-control form-control-sm" type="date" />
                                        <span asp-validation-for="Input.NgayKhoiHanh" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="Input.SoNguoiLon" class="form-label">Người lớn</label>
                                        <input asp-for="Input.SoNguoiLon" class="form-control form-control-sm" type="number" min="1" />
                                        <span asp-validation-for="Input.SoNguoiLon" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="Input.SoTreEm" class="form-label">Trẻ em</label>
                                        <input asp-for="Input.SoTreEm" class="form-control form-control-sm" type="number" min="0" />
                                        <span asp-validation-for="Input.SoTreEm" class="text-danger small"></span>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="Input.GhiChu" class="form-label">Ghi chú thêm (tùy chọn)</label>
                                        <textarea asp-for="Input.GhiChu" class="form-control form-control-sm" rows="2" placeholder="Yêu cầu riêng, thông tin liên hệ, thời gian dự kiến..."></textarea>
                                        <span asp-validation-for="Input.GhiChu" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        Đặt tour
                                    </button>
                                    <a asp-page="/Index" class="btn btn-outline-secondary btn-sm">Quay lại trang chủ</a>
                                </div>
                                <div class="text-muted small mt-2">
                                    Sau khi đặt, bạn có thể xem lại trong mục "Lịch sử đặt tour" của tài khoản.
                                </div>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
