@{
    var ngonNgu = Context.Request.Cookies["ngonngu"] ?? "vi";
}

<!DOCTYPE html>
<html lang="@(ngonNgu == "en" ? "en" : "vi")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VietTour</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TourOperatorWeb.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 navbar-main">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    VietTour
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">
                                @(ngonNgu == "en" ? "Home" : "Trang chủ")
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">
                                @(ngonNgu == "en" ? "Tours" : "Tour")
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" href="#">
                                @(ngonNgu == "en" ? "Flights" : "Vé máy bay")
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/KhachSan/Index">@(ngonNgu == "en" ? "Hotels" : "Khách sạn")</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/ThueXe/Index">@(ngonNgu == "en" ? "Car rental" : "Thuê xe")</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/TinTuc/Index">@(ngonNgu == "en" ? "News" : "Tin tức")</a>
                        </li>

                        @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("QuanTriHeThong"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Admin/TrangChuAdmin">
                                    @(ngonNgu == "en" ? "Admin" : "Trang quản trị")
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item me-3 d-flex align-items-center">
                                <a class="nav-link" asp-area="" asp-page="/TaiKhoan/ThongTin" title="@(ngonNgu == "en" ? "Account" : "Tài khoản")">
                                    <i class="bi bi-person-circle fs-4"></i>
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            @if (User?.Identity?.IsAuthenticated ?? false)
                            {
                                <form method="post" asp-page="/DangXuat" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        @(ngonNgu == "en" ? "Logout" : "Đăng xuất")
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-page="/DangNhap">
                                    @(ngonNgu == "en" ? "Login" : "Đăng nhập")
                                </a>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - TourOperatorWeb -
            <a asp-area="" asp-page="/Privacy">
                @(ngonNgu == "en" ? "Privacy" : "Chính sách riêng tư")
            </a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- 6. Cổng hỗ trợ trực tuyến (Floating Action Buttons) -->
    <div class="floating-support">
        <a href="#" class="btn-zalo" title="Chat Zalo">
            <span class="fw-bold">Z</span>
        </a>
        <a href="#" class="btn-messenger" title="Messenger">
            <i class="bi bi-messenger"></i>
        </a>
        <a href="tel:0123456789" class="btn-hotline" title="Gọi hotline">
            <i class="bi bi-telephone-fill"></i>
        </a>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
