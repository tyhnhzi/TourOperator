@page "{id:int}"
@model TourOperatorWeb.Pages.Admin.Tour_XoaModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "QuanTriHeThong")]
@{
    Layout = "_ModalLayout"; // Form hiển thị trong modal, dùng layout riêng không có header/footer
    ViewData["Title"] = "Xóa tour";
}

<div class="container py-4 crud-form-shell">
    <div class="crud-form-card">
        <h1 class="mb-3 text-danger">Xóa tour du lịch</h1>
        <div class="alert alert-warning">
        Bạn có chắc chắn muốn xóa tour <strong>@Model.Tour?.TenTour</strong> không?
        Hành động này không thể hoàn tác.
    </div>

    <dl class="row">
        <dt class="col-sm-2">Khởi hành</dt>
        <dd class="col-sm-10">@Model.Tour?.DiaDiemKhoiHanh</dd>
        <dt class="col-sm-2">Điểm đến</dt>
        <dd class="col-sm-10">@Model.Tour?.DiaDiemDen</dd>
        <dt class="col-sm-2">Giá từ</dt>
        <dd class="col-sm-10">@Model.Tour?.GiaTu.ToString("N0") đ</dd>
    </dl>

    <form method="post" class="crud-form-actions">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Xóa tour</button>
        <a asp-page="/Admin/QuanLyTour" class="btn btn-outline-secondary ms-2">Hủy</a>
    </form>
    </div>
</div>
