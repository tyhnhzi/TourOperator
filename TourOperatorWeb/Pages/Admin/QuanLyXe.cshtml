@page
@model TourOperatorWeb.Pages.Admin.QuanLyXeModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "QuanTriHeThong")]
@{
    ViewData["Title"] = "Quản lý xe";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Quản lý xe</h1>
            <p class="text-muted mb-0">Danh sách phương tiện phục vụ cho các tour.</p>
        </div>
        <div>
            <a href="#" class="btn btn-primary js-open-car-modal" data-url="/Admin/Xe_Them">+ Thêm xe</a>
        </div>
    </div>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Biển số</th>
                <th>Loại xe</th>
                <th>Số chỗ</th>
                <th>Tên tài xế</th>
                <th style="width: 150px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var xe in Model.DanhSachXe)
        {
            <tr>
                <td>@xe.BienSo</td>
                <td>@xe.LoaiXe</td>
                <td>@xe.SoChoNgoi</td>
                <td>@xe.TenTaiXe</td>
                <td>
                    <div class="btn-group btn-group-sm" role="group">
                        <a href="#" class="btn btn-outline-secondary js-open-car-modal" data-url="@Url.Page("/Admin/Xe_Sua", new { id = xe.Id })">Sửa</a>
                        <a href="#" class="btn btn-outline-danger js-open-car-modal" data-url="@Url.Page("/Admin/Xe_Xoa", new { id = xe.Id })">Xóa</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <a asp-page="/Admin/TrangChuAdmin" class="btn btn-secondary mt-3">Quay lại trang quản trị</a>

    <!-- Modal hiển thị form Thêm/Sửa/Xóa xe ngay trên trang danh sách -->
    <div class="modal fade" id="carModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Chi tiết xe</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body p-0">
                    <iframe id="carModalFrame" src="" style="border:0; width:100%; height:500px;"></iframe>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            (function () {
                const modalElement = document.getElementById('carModal');
                const frame = document.getElementById('carModalFrame');
                if (!modalElement || !frame || !window.bootstrap) {
                    return;
                }

                const modal = new bootstrap.Modal(modalElement);

                document.querySelectorAll('.js-open-car-modal').forEach(function (btn) {
                    btn.addEventListener('click', function (e) {
                        e.preventDefault();
                        const url = this.getAttribute('data-url');
                        if (!url) return;
                        frame.src = url;
                        modal.show();
                    });
                });

                modalElement.addEventListener('hidden.bs.modal', function () {
                    frame.src = '';
                });
            })();
        </script>
    }
</div>
