@page
@model TourOperatorWeb.Pages.KhachSanPages.IndexModel
@{
    ViewData["Title"] = "Khách sạn đối tác";
}

<div class="container py-4">
    <h1 class="mb-1">Khách sạn đối tác</h1>
    <p class="text-muted mb-3 small">Danh sách một số khách sạn VietTour đang hợp tác trong các chương trình tour.</p>

    @if (Model.DanhSachKhachSan == null || !Model.DanhSachKhachSan.Any())
    {
        <div class="alert alert-info small">Hiện chưa có dữ liệu khách sạn.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-3">
            @foreach (var ks in Model.DanhSachKhachSan)
            {
                <div class="col">
                    <div class="card shadow-sm h-100 admin-card-hover border-0">
                        <div class="card-body">
                            <h2 class="h6 mb-1">@ks.TenKhachSan</h2>
                            <p class="text-muted small mb-1">
                                <i class="bi bi-geo-alt me-1"></i>@(string.IsNullOrWhiteSpace(ks.DiaChi) ? "Đang cập nhật" : ks.DiaChi)
                            </p>
                            <p class="text-muted small mb-0">
                                <i class="bi bi-telephone me-1"></i>@(string.IsNullOrWhiteSpace(ks.SoDienThoai) ? "Đang cập nhật" : ks.SoDienThoai)
                            </p>
                            @if (User?.Identity?.IsAuthenticated ?? false)
                            {
                                <div class="mt-2">
                                    <a asp-page="/KhachSan/Dat" asp-route-id="@ks.Id" class="btn btn-primary btn-sm">Đặt khách sạn</a>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small mt-2 mb-0">
                                    Vui lòng <a asp-page="/DangNhap">đăng nhập</a> để gửi yêu cầu đặt phòng.
                                </p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
