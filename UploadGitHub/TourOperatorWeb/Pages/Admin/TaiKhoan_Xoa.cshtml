@page "{id:int}"
@model TourOperatorWeb.Pages.Admin.TaiKhoan_XoaModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "QuanTriHeThong")]
@{
    Layout = "_ModalLayout"; // Form hiển thị trong modal, dùng layout riêng không có header/footer
    ViewData["Title"] = "Xóa tài khoản người dùng";
}

<div class="container py-4 crud-form-shell">
    <div class="crud-form-card">
        <h2 class="mb-3 text-danger">Xóa tài khoản người dùng</h2>

        @if (Model.TenDangNhap == null)
        {
            <div class="alert alert-warning">Không tìm thấy tài khoản cần xóa.</div>
            <div class="crud-form-actions mt-3">
                <a asp-page="/Admin/QuanLyTaiKhoan" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        }
        else
        {
            <div class="alert alert-danger">
                Bạn có chắc chắn muốn xóa tài khoản <strong>@Model.TenDangNhap</strong> không?
            </div>

            <form method="post" class="crud-form-actions mt-3">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Xóa</button>
                <a asp-page="/Admin/QuanLyTaiKhoan" class="btn btn-secondary ms-2">Hủy</a>
            </form>
        }
    </div>
</div>
