@page
@model TourOperatorWeb.Pages.Tour.IndexModel
@{
    ViewData["Title"] = "Danh sách tour";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="h3 mb-1">Danh sách tour</h1>
            <p class="text-muted mb-0">Khám phá các tour du lịch đang mở bán của VietTour.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-10">
                    <label asp-for="TuKhoa" class="form-label">Tìm kiếm tour</label>
                    <input asp-for="TuKhoa" class="form-control" placeholder="Nhập tên tour, điểm khởi hành hoặc điểm đến..." />
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i>Tìm
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.DanhSachTour.Any())
    {
        <div class="alert alert-warning">
            Không tìm thấy tour phù hợp.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var tour in Model.DanhSachTour)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        @if (!string.IsNullOrWhiteSpace(tour.AnhDaiDien))
                        {
                            <img src="@tour.AnhDaiDien" alt="@tour.TenTour" class="card-img-top" style="height: 220px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 220px;">
                                <span class="text-muted">Chưa có ảnh</span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <div class="mb-2">
                                @if (tour.LaDeXuat)
                                {
                                    <span class="badge bg-warning text-dark">Đề xuất</span>
                                }
                            </div>

                            <h5 class="card-title">@tour.TenTour</h5>

                            <p class="text-muted small mb-2">
                                <i class="bi bi-geo-alt me-1"></i>@tour.DiaDiemKhoiHanh → @tour.DiaDiemDen
                            </p>

                            <p class="text-muted small mb-2">
                                <i class="bi bi-clock me-1"></i>@tour.SoNgay ngày
                            </p>

                            @if (!string.IsNullOrWhiteSpace(tour.MoTaNgan))
                            {
                                <p class="card-text text-secondary small flex-grow-1">@tour.MoTaNgan</p>
                            }
                            else
                            {
                                <p class="card-text text-secondary small flex-grow-1">Tour trọn gói, lịch trình linh hoạt và phù hợp cho nhiều nhóm khách.</p>
                            }

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div>
                                    <div class="small text-muted">Giá từ</div>
                                    <div class="fw-bold text-danger fs-5">@tour.GiaTu.ToString("N0") đ</div>
                                </div>
                                <a asp-page="/Tour/ChiTiet" asp-route-id="@tour.Id" class="btn btn-primary btn-sm">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>