@page
@model TourOperatorWeb.Pages.Admin.TaiKhoan_ThemModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "QuanTriHeThong")]
@{
    Layout = "_ModalLayout"; // Form hiển thị trong modal, dùng layout riêng không có header/footer
    ViewData["Title"] = "Thêm tài khoản người dùng";
}

<div class="container py-4 crud-form-shell">
    <div class="crud-form-card">
        <h2 class="mb-3">Thêm tài khoản người dùng</h2>

        <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Input.TenDangNhap" class="form-label">Tên đăng nhập *</label>
            <input asp-for="Input.TenDangNhap" class="form-control" />
            <span asp-validation-for="Input.TenDangNhap" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.MatKhau" class="form-label">Mật khẩu *</label>
            <input asp-for="Input.MatKhau" class="form-control" />
            <span asp-validation-for="Input.MatKhau" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.VaiTroId" class="form-label">Vai trò *</label>
            <select asp-for="Input.VaiTroId" asp-items="Model.DanhSachVaiTro" class="form-select">
                <option value="">-- Chọn vai trò --</option>
            </select>
            <span asp-validation-for="Input.VaiTroId" class="text-danger"></span>
        </div>

        <div class="crud-form-actions">
            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-page="/Admin/QuanLyTaiKhoan" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
    </div>
</div>
