@page
@model TourOperatorWeb.Pages.ThueXe.IndexModel
@{
    ViewData["Title"] = "Dịch vụ thuê xe";
}

<div class="container py-4">
    <h1 class="mb-1">Dịch vụ thuê xe riêng</h1>
    <p class="text-muted mb-3 small">Danh sách một số xe và tài xế VietTour đang vận hành cho các tuyến tour và thuê riêng.</p>

    @if (Model.DanhSachXe == null || !Model.DanhSachXe.Any())
    {
        <div class="alert alert-info small">Hiện chưa có dữ liệu xe.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Biển số</th>
                        <th>Loại xe</th>
                        <th class="text-end">Số chỗ</th>
                        <th>Tài xế phụ trách</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var xe in Model.DanhSachXe)
                    {
                        <tr>
                            <td>@xe.BienSo</td>
                            <td>@(string.IsNullOrWhiteSpace(xe.LoaiXe) ? "Đang cập nhật" : xe.LoaiXe)</td>
                            <td class="text-end">@(xe.SoChoNgoi?.ToString() ?? "-")</td>
                            <td>@(string.IsNullOrWhiteSpace(xe.TenTaiXe) ? "Đang cập nhật" : xe.TenTaiXe)</td>
                            <td class="text-end">
                                @if (User?.Identity?.IsAuthenticated ?? false)
                                {
                                    <a asp-page="/ThueXe/Dat" asp-route-id="@xe.Id" class="btn btn-primary btn-sm">Thuê xe</a>
                                }
                                else
                                {
                                    <span class="text-muted small">Đăng nhập để gửi yêu cầu</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
