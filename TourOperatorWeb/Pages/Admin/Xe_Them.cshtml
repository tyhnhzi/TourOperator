@page
@model TourOperatorWeb.Pages.Admin.Xe_ThemModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "QuanTriHeThong")]
@{
    Layout = "_ModalLayout"; // Form hiển thị trong modal, dùng layout riêng không có header/footer
    ViewData["Title"] = "Thêm xe";
}

<div class="container py-4 crud-form-shell">
    <div class="crud-form-card">
        <h2 class="mb-3">Thêm xe</h2>

        <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Xe.BienSo" class="form-label">Biển số *</label>
            <input asp-for="Xe.BienSo" class="form-control" />
            <span asp-validation-for="Xe.BienSo" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Xe.LoaiXe" class="form-label">Loại xe</label>
            <input asp-for="Xe.LoaiXe" class="form-control" />
            <span asp-validation-for="Xe.LoaiXe" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Xe.SoChoNgoi" class="form-label">Số chỗ ngồi</label>
            <input asp-for="Xe.SoChoNgoi" class="form-control" />
            <span asp-validation-for="Xe.SoChoNgoi" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Xe.TenTaiXe" class="form-label">Tên tài xế</label>
            <input asp-for="Xe.TenTaiXe" class="form-control" />
            <span asp-validation-for="Xe.TenTaiXe" class="text-danger"></span>
        </div>

        <div class="crud-form-actions mt-4">
            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-page="/Admin/QuanLyXe" class="btn btn-secondary ms-2">Quay lại</a>
        </div>
        </form>

        @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        }
    </div>
</div>
